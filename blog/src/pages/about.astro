---
import BaseLayout from '../components/BaseLayout.astro';
---

<BaseLayout title="About — Vahagn Grigoryan" description="About Vahagn Grigoryan — software architect and engineer.">
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">

    <!-- Hero / Intro -->
    <section>
      <p class="text-sm font-medium tracking-widest uppercase text-primary-500 dark:text-primary-400">
        About
      </p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-secondary-900 dark:text-secondary-100 sm:text-4xl">
        Vahagn Grigoryan
      </h1>
      <p class="mt-1 text-lg text-primary-600 dark:text-primary-400 font-medium">
        Software Architect &amp; Engineer
      </p>

      <div class="mt-8 space-y-4 text-secondary-600 dark:text-secondary-400 leading-relaxed">
        <p>
          I design and build systems that handle real-world complexity — distributed platforms, high-throughput data
          pipelines, and the infrastructure that keeps them running. My work sits at the intersection of architecture
          and hands-on engineering: I care as much about a clean API contract as I do about the tail latency behind it.
        </p>
        <p>
          Over the years I've shipped production systems across security, networking, trading, and AI/ML — each domain
          demanding its own trade-offs between correctness, performance, and operational simplicity. I gravitate toward
          problems where the architecture <em>is</em> the product: where getting the abstractions right determines
          whether the system scales or collapses.
        </p>
        <p>
          Outside of building, I write about system design, engineering craft, and the decisions that shape software
          over time. I believe the best technical writing starts with real problems and ends with reusable mental models.
        </p>
      </div>
    </section>

    <!-- Divider -->
    <hr class="my-14 border-secondary-200 dark:border-secondary-800" />

    <!-- Current Focus -->
    <section>
      <h2 class="text-xl font-semibold text-secondary-900 dark:text-secondary-100">
        Current Focus
      </h2>
      <p class="mt-2 text-secondary-500 dark:text-secondary-400 text-sm">
        The domains I'm actively thinking about and building in.
      </p>

      <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <!-- Focus card 1 -->
        <div class="rounded-lg border border-secondary-200 dark:border-secondary-800 p-5 bg-secondary-50 dark:bg-secondary-900/50">
          <div class="flex items-center gap-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-md bg-primary-500/10 dark:bg-primary-400/10 text-primary-600 dark:text-primary-400">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2" />
              </svg>
            </span>
            <h3 class="font-medium text-secondary-900 dark:text-secondary-100">Distributed Systems</h3>
          </div>
          <p class="mt-3 text-sm text-secondary-500 dark:text-secondary-400">
            Consensus protocols, event-driven architectures, and the operational patterns that keep distributed systems reliable at scale.
          </p>
        </div>

        <!-- Focus card 2 -->
        <div class="rounded-lg border border-secondary-200 dark:border-secondary-800 p-5 bg-secondary-50 dark:bg-secondary-900/50">
          <div class="flex items-center gap-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-md bg-accent-500/10 dark:bg-accent-400/10 text-accent-600 dark:text-accent-400">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </span>
            <h3 class="font-medium text-secondary-900 dark:text-secondary-100">AI/ML Infrastructure</h3>
          </div>
          <p class="mt-3 text-sm text-secondary-500 dark:text-secondary-400">
            Model serving pipelines, feature stores, and the platform engineering required to move ML workloads from notebooks to production.
          </p>
        </div>

        <!-- Focus card 3 -->
        <div class="rounded-lg border border-secondary-200 dark:border-secondary-800 p-5 bg-secondary-50 dark:bg-secondary-900/50">
          <div class="flex items-center gap-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-md bg-primary-500/10 dark:bg-primary-400/10 text-primary-600 dark:text-primary-400">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.384-3.19A1 1 0 015 11.14V6.86a1 1 0 011.036-.838l5.384.637a1 1 0 01.895.764l1.017 4.452a1 1 0 01-.523 1.108l-1.389.72zM19.577 15.17l-5.384-3.19A1 1 0 0113.157 11.14V6.86a1 1 0 011.036-.838l5.384.637" />
              </svg>
            </span>
            <h3 class="font-medium text-secondary-900 dark:text-secondary-100">Developer Tools</h3>
          </div>
          <p class="mt-3 text-sm text-secondary-500 dark:text-secondary-400">
            CLIs, build systems, and internal platforms that improve developer velocity — treating the development experience as a product.
          </p>
        </div>

        <!-- Focus card 4 -->
        <div class="rounded-lg border border-secondary-200 dark:border-secondary-800 p-5 bg-secondary-50 dark:bg-secondary-900/50">
          <div class="flex items-center gap-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-md bg-accent-500/10 dark:bg-accent-400/10 text-accent-600 dark:text-accent-400">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </span>
            <h3 class="font-medium text-secondary-900 dark:text-secondary-100">Security Engineering</h3>
          </div>
          <p class="mt-3 text-sm text-secondary-500 dark:text-secondary-400">
            Threat modeling, zero-trust architectures, and building security into systems by default rather than bolting it on after the fact.
          </p>
        </div>
      </div>
    </section>

    <!-- Divider -->
    <hr class="my-14 border-secondary-200 dark:border-secondary-800" />

    <!-- Skills & Tech Stack -->
    <section>
      <h2 class="text-xl font-semibold text-secondary-900 dark:text-secondary-100">
        Skills &amp; Tech Stack
      </h2>
      <p class="mt-2 text-secondary-500 dark:text-secondary-400 text-sm">
        Technologies and tools I reach for, organized by what they do.
      </p>

      <div class="mt-6 space-y-6">

        <!-- Languages -->
        <div>
          <h3 class="text-xs font-semibold tracking-widest uppercase text-secondary-400 dark:text-secondary-500 mb-3">
            Languages
          </h3>
          <div class="flex flex-wrap gap-2">
            {['TypeScript', 'Python', 'Go', 'Rust', 'Java', 'C++', 'SQL', 'Bash'].map((skill) => (
              <span class="inline-flex items-center rounded-md bg-secondary-100 dark:bg-secondary-800 px-3 py-1 text-sm font-medium text-secondary-700 dark:text-secondary-300 ring-1 ring-inset ring-secondary-200 dark:ring-secondary-700">
                {skill}
              </span>
            ))}
          </div>
        </div>

        <!-- Frameworks & Libraries -->
        <div>
          <h3 class="text-xs font-semibold tracking-widest uppercase text-secondary-400 dark:text-secondary-500 mb-3">
            Frameworks &amp; Libraries
          </h3>
          <div class="flex flex-wrap gap-2">
            {['React', 'Node.js', 'FastAPI', 'Spring Boot', 'Astro', 'Next.js', 'gRPC', 'GraphQL'].map((skill) => (
              <span class="inline-flex items-center rounded-md bg-secondary-100 dark:bg-secondary-800 px-3 py-1 text-sm font-medium text-secondary-700 dark:text-secondary-300 ring-1 ring-inset ring-secondary-200 dark:ring-secondary-700">
                {skill}
              </span>
            ))}
          </div>
        </div>

        <!-- Infrastructure & Cloud -->
        <div>
          <h3 class="text-xs font-semibold tracking-widest uppercase text-secondary-400 dark:text-secondary-500 mb-3">
            Infrastructure &amp; Cloud
          </h3>
          <div class="flex flex-wrap gap-2">
            {['AWS', 'GCP', 'Kubernetes', 'Docker', 'Terraform', 'PostgreSQL', 'Redis', 'Kafka'].map((skill) => (
              <span class="inline-flex items-center rounded-md bg-secondary-100 dark:bg-secondary-800 px-3 py-1 text-sm font-medium text-secondary-700 dark:text-secondary-300 ring-1 ring-inset ring-secondary-200 dark:ring-secondary-700">
                {skill}
              </span>
            ))}
          </div>
        </div>

        <!-- Tools & Practices -->
        <div>
          <h3 class="text-xs font-semibold tracking-widest uppercase text-secondary-400 dark:text-secondary-500 mb-3">
            Tools &amp; Practices
          </h3>
          <div class="flex flex-wrap gap-2">
            {['Git', 'GitHub Actions', 'Prometheus', 'Grafana', 'OpenTelemetry', 'ArgoCD', 'Nginx', 'Linux'].map((skill) => (
              <span class="inline-flex items-center rounded-md bg-secondary-100 dark:bg-secondary-800 px-3 py-1 text-sm font-medium text-secondary-700 dark:text-secondary-300 ring-1 ring-inset ring-secondary-200 dark:ring-secondary-700">
                {skill}
              </span>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- Divider -->
    <hr class="my-14 border-secondary-200 dark:border-secondary-800" />

    <!-- Get in Touch -->
    <section>
      <h2 class="text-xl font-semibold text-secondary-900 dark:text-secondary-100">
        Get in Touch
      </h2>
      <p class="mt-2 text-secondary-500 dark:text-secondary-400 text-sm">
        Always open to conversations about architecture, engineering, and interesting problems.
      </p>

      <div class="mt-6 flex flex-wrap gap-4">
        <!-- GitHub -->
        <a
          href="https://github.com/vahagn-grigoryan"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="inline-flex items-center gap-2.5 rounded-lg border border-secondary-200 dark:border-secondary-800 bg-secondary-50 dark:bg-secondary-900/50 px-5 py-3 text-sm font-medium text-secondary-700 dark:text-secondary-300 hover:border-primary-300 dark:hover:border-primary-700 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0016 8c0-4.42-3.58-8-8-8z" />
          </svg>
          GitHub
        </a>

        <!-- LinkedIn -->
        <a
          href="https://linkedin.com/in/vahagn-grigoryan"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="inline-flex items-center gap-2.5 rounded-lg border border-secondary-200 dark:border-secondary-800 bg-secondary-50 dark:bg-secondary-900/50 px-5 py-3 text-sm font-medium text-secondary-700 dark:text-secondary-300 hover:border-primary-300 dark:hover:border-primary-700 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
          LinkedIn
        </a>

        <!-- X (Twitter) -->
        <a
          href="https://x.com/vahagn_dev"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="X (Twitter)"
          class="inline-flex items-center gap-2.5 rounded-lg border border-secondary-200 dark:border-secondary-800 bg-secondary-50 dark:bg-secondary-900/50 px-5 py-3 text-sm font-medium text-secondary-700 dark:text-secondary-300 hover:border-primary-300 dark:hover:border-primary-700 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
          X (Twitter)
        </a>

        <!-- Email -->
        <a
          href="mailto:hello@vahagn.dev"
          aria-label="Email"
          class="inline-flex items-center gap-2.5 rounded-lg border border-secondary-200 dark:border-secondary-800 bg-secondary-50 dark:bg-secondary-900/50 px-5 py-3 text-sm font-medium text-secondary-700 dark:text-secondary-300 hover:border-primary-300 dark:hover:border-primary-700 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Email
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
