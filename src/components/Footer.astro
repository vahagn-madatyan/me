---
const year = new Date().getFullYear();
---

<footer class="border-t border-secondary-200 dark:border-white/[0.06] bg-secondary-50 dark:bg-white/[0.02]">
  <div class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
    <div class="flex flex-col items-center gap-6 sm:flex-row sm:justify-between">
      <!-- Copyright -->
      <p class="text-sm font-code text-secondary-500 dark:text-secondary-400">
        &copy; {year} Vahagn Madatyan
      </p>

      <!-- Social + RSS links -->
      <div class="flex items-center gap-4">
        <a
          href="https://github.com/vahagn-madatyan"
          target="_blank"
          rel="noopener noreferrer"
          class="text-secondary-400 hover:text-secondary-600 dark:text-secondary-500 dark:hover:text-primary-400 dark:hover:drop-shadow-[0_0_6px_rgba(16,185,129,0.4)] transition-colors"
          aria-label="GitHub"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0016 8c0-4.42-3.58-8-8-8z" />
          </svg>
        </a>
        <a
          href="https://linkedin.com/in/mvahagn"
          target="_blank"
          rel="noopener noreferrer"
          class="text-secondary-400 hover:text-secondary-600 dark:text-secondary-500 dark:hover:text-primary-400 dark:hover:drop-shadow-[0_0_6px_rgba(16,185,129,0.4)] transition-colors"
          aria-label="LinkedIn"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
        </a>
        <a
          href="https://x.com/vahagndev"
          target="_blank"
          rel="noopener noreferrer"
          class="text-secondary-400 hover:text-secondary-600 dark:text-secondary-500 dark:hover:text-primary-400 dark:hover:drop-shadow-[0_0_6px_rgba(16,185,129,0.4)] transition-colors"
          aria-label="X (Twitter)"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        </a>
        <span class="w-px h-4 bg-secondary-300 dark:bg-secondary-700" aria-hidden="true"></span>
        <a
          href="/rss.xml"
          class="text-secondary-400 hover:text-secondary-600 dark:text-secondary-500 dark:hover:text-primary-400 dark:hover:drop-shadow-[0_0_6px_rgba(16,185,129,0.4)] transition-colors"
          aria-label="RSS Feed"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795 0 3.251 1.454 3.251 3.248zM.002 0v5.626c10.148 0 18.372 8.224 18.372 18.374h5.626C24 10.756 13.244 0 .002 0zm0 7.812v5.627c5.842 0 10.563 4.721 10.563 10.561h5.627C16.192 15.634 8.37 7.812.002 7.812z" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .dark footer {
    box-shadow: 0 -1px 0 rgba(16, 185, 129, 0.08);
  }
</style>
