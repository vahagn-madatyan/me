---
// ThemeToggle: cycles light → dark → system, persists to localStorage, no FOUC
---

<button
  type="button"
  aria-label="Toggle theme"
  data-theme-toggle
  class="theme-toggle relative flex items-center justify-center w-9 h-9 rounded-lg
         text-secondary-500 hover:text-secondary-900 dark:text-secondary-400 dark:hover:text-secondary-100
         hover:bg-secondary-100 dark:hover:bg-secondary-800
         transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500"
>
  <!-- Sun icon (shown in dark mode — click to go light) -->
  <svg
    data-theme-icon="sun"
    class="hidden w-5 h-5"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round"
      d="M12 3v1m0 16v1m8.66-13.66l-.71.71M4.05 19.95l-.71.71M21 12h-1M4 12H3m16.66 7.66l-.71-.71M4.05 4.05l-.71-.71M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
  </svg>
  <!-- Moon icon (shown in light mode — click to go dark) -->
  <svg
    data-theme-icon="moon"
    class="hidden w-5 h-5"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round"
      d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
  </svg>
  <!-- Monitor icon (shown in system mode) -->
  <svg
    data-theme-icon="system"
    class="hidden w-5 h-5"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round"
      d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
  </svg>
</button>

<script>
  // Track current setting at module scope so all instances share state
  let currentTheme: 'light' | 'dark' | 'system' = 'system';

  function getStoredTheme(): 'light' | 'dark' | 'system' {
    const stored = localStorage.getItem('theme');
    if (stored === 'light' || stored === 'dark') return stored;
    return 'system';
  }

  function syncAllButtons(setting: 'light' | 'dark' | 'system') {
    document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
      const sunIcon = btn.querySelector('[data-theme-icon="sun"]');
      const moonIcon = btn.querySelector('[data-theme-icon="moon"]');
      const systemIcon = btn.querySelector('[data-theme-icon="system"]');

      if (sunIcon) sunIcon.classList.toggle('hidden', setting !== 'dark');
      if (moonIcon) moonIcon.classList.toggle('hidden', setting !== 'light');
      if (systemIcon) systemIcon.classList.toggle('hidden', setting !== 'system');

      const label = setting === 'system' ? 'Theme: system' : `Theme: ${setting}`;
      btn.setAttribute('aria-label', label);
    });
  }

  function applyTheme(setting: 'light' | 'dark' | 'system') {
    const isDark =
      setting === 'dark' ||
      (setting === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);

    document.documentElement.classList.toggle('dark', isDark);
    syncAllButtons(setting);
  }

  function nextTheme(current: 'light' | 'dark' | 'system'): 'light' | 'dark' | 'system' {
    if (current === 'light') return 'dark';
    if (current === 'dark') return 'system';
    return 'light';
  }

  function handleToggleClick() {
    document.documentElement.classList.add('theme-transition');
    currentTheme = nextTheme(currentTheme);
    if (currentTheme === 'system') {
      localStorage.removeItem('theme');
    } else {
      localStorage.setItem('theme', currentTheme);
    }
    applyTheme(currentTheme);
  }

  function initThemeToggles() {
    currentTheme = getStoredTheme();
    applyTheme(currentTheme);

    // Use onclick assignment — auto-replaces on re-init (safe for HMR + transitions)
    document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
      (btn as HTMLElement).onclick = handleToggleClick;
    });
  }

  initThemeToggles();
  document.addEventListener('astro:after-swap', initThemeToggles);

  // React to system preference changes when in "system" mode
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if (getStoredTheme() === 'system') {
      applyTheme('system');
    }
  });
</script>
