---
import BaseLayout from '../../components/BaseLayout.astro';
import { architectures } from '../../data/architectures';

const projects = [
  {
    id: 'token-for-granted',
    title: 'Token for Granted',
    description: 'Full-stack AI valuation dashboard running entirely on Cloudflare\'s edge — Workers, D1, KV, AI Gateway, and Workers AI.',
    href: '/architecture/token-for-granted',
    tags: ['Cloudflare Workers', 'AI Gateway', 'Workers AI', 'D1', 'KV', 'TanStack Start'],
  },
  {
    id: 'netsec-skills-suite',
    title: 'NetSec Skills Suite',
    description: '35+ agent skills organized across five domains — device health, routing, security, cloud, and observability.',
    href: '/architecture/netsec-skills-suite',
    tags: ['AI Agents', 'Network Security', 'Multi-Vendor', 'Open Source'],
  },
];

const projectIds = ['all', ...projects.map((p) => p.id)] as const;

function domainLabel(domain: string): string {
  return domain
    .split('-')
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
}
---

<BaseLayout title="Architecture — Vahagn Madatyan" description="Interactive architecture deep dives for my projects — Cloudflare edge AI, network security agent skills, and more.">
  <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6">
    <h1 class="text-3xl font-bold tracking-tight text-secondary-900 dark:text-secondary-100 sm:text-4xl">
      Architecture
    </h1>
    <p class="mt-3 text-secondary-600 dark:text-secondary-400 leading-relaxed">
      Interactive architecture deep dives — how my projects are designed, what decisions were made, and how the pieces fit together.
    </p>

    <!-- Project filter buttons -->
    <div class="mt-8 flex flex-wrap gap-2 mb-8">
      {projectIds.map((pid) => (
        <button
          data-filter={pid}
          class:list={[
            'rounded-full px-4 py-1.5 text-sm font-medium transition-colors cursor-pointer',
            pid === 'all'
              ? 'bg-primary-500 text-white dark:shadow-[0_0_15px_rgba(16,185,129,0.25)]'
              : 'bg-secondary-100 text-secondary-600 hover:bg-secondary-200 dark:bg-white/[0.05] dark:text-secondary-300 dark:hover:bg-white/[0.1] dark:ring-1 dark:ring-white/[0.06]',
          ]}
        >
          {pid === 'all' ? 'All' : projects.find((p) => p.id === pid)?.title}
        </button>
      ))}
    </div>

    <!-- Project cards -->
    <div class="grid grid-cols-1 gap-6" id="project-grid">
      {projects.map((project) => (
        <div data-category={project.id}>
          <a
            href={project.href}
            class="block rounded-2xl bg-white shadow-sm ring-1 ring-secondary-200 transition-all duration-300 hover:shadow-lg hover:ring-primary-300 dark:bg-secondary-900 dark:ring-secondary-800 dark:hover:ring-primary-700 overflow-hidden"
          >
            <div class="p-5 sm:p-6">
              <h3 class="text-lg font-semibold leading-snug tracking-tight text-secondary-900 dark:text-secondary-100">
                {project.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-secondary-600 dark:text-secondary-400">
                {project.description}
              </p>
              <div class="mt-4 flex flex-wrap gap-1.5">
                {project.tags.map((tag) => (
                  <span class="rounded-full bg-primary-100 px-2 py-0.5 text-xs font-medium text-primary-800 dark:bg-primary-900 dark:text-primary-200">
                    {tag}
                  </span>
                ))}
              </div>
              <div class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-primary-500">
                Explore architecture
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              </div>
            </div>
          </a>
        </div>
      ))}
    </div>

    <!-- Architecture card grid (domain-level cards) -->
    <h2 class="mt-16 text-2xl font-bold tracking-tight text-secondary-900 dark:text-secondary-100">
      All Components
    </h2>
    <p class="mt-2 text-secondary-600 dark:text-secondary-400 leading-relaxed mb-8">
      Individual architecture components across all projects.
    </p>

    <div class="grid grid-cols-1 gap-8" id="architecture-grid">
      {architectures.map((arch) => (
        <div data-category={arch.project}>
          <article
            class="rounded-2xl bg-white shadow-sm ring-1 ring-secondary-200 transition-all duration-300 hover:shadow-lg hover:ring-primary-300 dark:bg-secondary-900 dark:ring-secondary-800 dark:hover:ring-primary-700 overflow-hidden"
          >
            {arch.mermaid && (
              <div class="border-b border-secondary-200 dark:border-secondary-700 bg-secondary-50 dark:bg-secondary-800/50 p-6 overflow-x-auto">
                <pre class="mermaid flex justify-center text-sm">{arch.mermaid}</pre>
              </div>
            )}

            <div class="p-5 sm:p-6">
              <div class="flex items-center gap-2">
                <span class="inline-flex items-center rounded-full bg-primary-100 px-2.5 py-0.5 text-xs font-medium text-primary-800 dark:bg-primary-900 dark:text-primary-200">
                  {domainLabel(arch.domain)}
                </span>
                <span class="inline-flex items-center rounded-full bg-secondary-100 px-2.5 py-0.5 text-xs font-medium text-secondary-600 dark:bg-secondary-800 dark:text-secondary-400">
                  {projects.find((p) => p.id === arch.project)?.title}
                </span>
              </div>

              <h3 class="mt-2 text-lg font-semibold leading-snug tracking-tight text-secondary-900 dark:text-secondary-100">
                {arch.title}
              </h3>

              <p class="mt-2 text-sm leading-relaxed text-secondary-600 dark:text-secondary-400">
                {arch.description}
              </p>

              <div class="mt-3">
                <p class="text-xs font-semibold tracking-wider uppercase text-secondary-400 dark:text-secondary-500">
                  Problem Solved
                </p>
                <p class="mt-1 text-sm leading-relaxed text-secondary-500 dark:text-secondary-400">
                  {arch.problemSolved}
                </p>
              </div>

              {arch.techDecisions.length > 0 && (
                <div class="mt-4 flex flex-wrap gap-1.5">
                  {arch.techDecisions.map((tech) => (
                    <span class="rounded-full bg-primary-100 px-2 py-0.5 text-xs font-medium text-primary-800 dark:bg-primary-900 dark:text-primary-200">
                      {tech}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </article>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<script is:inline type="module">
  import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

  function initPage() {
    const isDark = document.documentElement.classList.contains('dark');
    mermaid.initialize({
      startOnLoad: false,
      theme: isDark ? 'dark' : 'default',
      flowchart: { curve: 'basis', padding: 15 },
    });
    mermaid.run({ querySelector: '.mermaid' });

    const ACTIVE_CLASSES = ['bg-primary-500', 'text-white', 'dark:shadow-[0_0_15px_rgba(16,185,129,0.25)]'];
    const INACTIVE_CLASSES = [
      'bg-secondary-100', 'text-secondary-600', 'hover:bg-secondary-200',
      'dark:bg-white/[0.05]', 'dark:text-secondary-300', 'dark:hover:bg-white/[0.1]',
      'dark:ring-1', 'dark:ring-white/[0.06]',
    ];

    const buttons = document.querySelectorAll('[data-filter]');
    const cards = document.querySelectorAll('[data-category]');

    function setActive(btn) {
      buttons.forEach((b) => {
        ACTIVE_CLASSES.forEach((c) => b.classList.remove(c));
        INACTIVE_CLASSES.forEach((c) => b.classList.add(c));
      });
      INACTIVE_CLASSES.forEach((c) => btn.classList.remove(c));
      ACTIVE_CLASSES.forEach((c) => btn.classList.add(c));
    }

    function filterCards(category) {
      cards.forEach((card) => {
        if (category === 'all' || card.dataset.category === category) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    }

    const allBtn = document.querySelector('[data-filter="all"]');
    if (allBtn) setActive(allBtn);
    filterCards('all');

    buttons.forEach((btn) => {
      btn.onclick = () => {
        const category = btn.dataset.filter ?? 'all';
        setActive(btn);
        filterCards(category);
      };
    });
  }

  initPage();
  document.addEventListener('astro:after-swap', initPage);
</script>
