---
import BaseLayout from '../components/BaseLayout.astro';
---

<BaseLayout title="About — Vahagn Madatyan" description="About Vahagn Madatyan — software developer, network engineer, and security architect.">
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">

    <!-- Hero / Intro -->
    <section>
      <p class="text-sm font-medium tracking-widest uppercase font-code text-primary-500 dark:text-primary-400">
        About
      </p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-secondary-900 dark:text-secondary-100 sm:text-4xl">
        Vahagn Madatyan
      </h1>
      <p class="mt-1 text-lg text-primary-600 dark:text-primary-400 font-medium">
        Software Developer · Network Engineer · Security Architect
      </p>

      <div class="mt-8 space-y-4 text-secondary-600 dark:text-secondary-400 leading-relaxed">
        <p>
          I build things that run while I sleep — trading bots, security automation, AI agents, and the infrastructure
          that keeps them all alive 24/7.
        </p>
        <p>
          Currently at <strong class="text-secondary-900 dark:text-secondary-100">Accenture</strong> leading global
          cybersecurity, zero trust, and enterprise network architecture, automations &amp; assets. Outside of that,
          I'm deep in the weeds building agentic AI systems, automating options strategies, and shipping open source
          tools for network security.
        </p>
        <p>
          I automate everything — if I do it twice, I build a bot for it. I ship fast, iterate faster, and I'm
          currently managing 20+ concurrent AI-assisted projects across security, trading, and developer tooling.
        </p>
      </div>
    </section>

    <!-- Divider -->
    <hr class="my-14 border-secondary-200 dark:border-white/[0.08]" />

    <!-- Current Focus -->
    <section>
      <h2 class="text-xl font-semibold text-secondary-900 dark:text-secondary-100">
        Current Focus
      </h2>
      <p class="mt-2 text-secondary-500 dark:text-secondary-400 text-sm">
        The domains I'm actively building in.
      </p>

      <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <!-- Focus card 1 -->
        <div class="rounded-lg border border-secondary-200 dark:border-white/[0.08] p-5 bg-secondary-50 dark:bg-white/[0.03] dark:backdrop-blur-xl">
          <div class="flex items-center gap-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-md bg-primary-500/10 dark:bg-primary-400/10 text-primary-600 dark:text-primary-400">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </span>
            <h3 class="font-medium text-secondary-900 dark:text-secondary-100">Cybersecurity &amp; Zero Trust</h3>
          </div>
          <p class="mt-3 text-sm text-secondary-500 dark:text-secondary-400">
            Zero trust architectures, AI-powered policy engines, offensive security tooling, and enterprise security automation at global scale.
          </p>
        </div>

        <!-- Focus card 2 -->
        <div class="rounded-lg border border-secondary-200 dark:border-white/[0.08] p-5 bg-secondary-50 dark:bg-white/[0.03] dark:backdrop-blur-xl">
          <div class="flex items-center gap-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-md bg-accent-500/10 dark:bg-accent-400/10 text-accent-600 dark:text-accent-400">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </span>
            <h3 class="font-medium text-secondary-900 dark:text-secondary-100">Agentic AI Systems</h3>
          </div>
          <p class="mt-3 text-sm text-secondary-500 dark:text-secondary-400">
            Building autonomous AI agents with LangChain, LangGraph, and MCP — from pentesting agents to trading bots to multi-agent orchestration dashboards.
          </p>
        </div>

        <!-- Focus card 3 -->
        <div class="rounded-lg border border-secondary-200 dark:border-white/[0.08] p-5 bg-secondary-50 dark:bg-white/[0.03] dark:backdrop-blur-xl">
          <div class="flex items-center gap-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-md bg-primary-500/10 dark:bg-primary-400/10 text-primary-600 dark:text-primary-400">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2" />
              </svg>
            </span>
            <h3 class="font-medium text-secondary-900 dark:text-secondary-100">Network Engineering</h3>
          </div>
          <p class="mt-3 text-sm text-secondary-500 dark:text-secondary-400">
            Enterprise network architecture, Juniper/Mist management via MCP, and open source tooling for network security operations.
          </p>
        </div>

        <!-- Focus card 4 -->
        <div class="rounded-lg border border-secondary-200 dark:border-white/[0.08] p-5 bg-secondary-50 dark:bg-white/[0.03] dark:backdrop-blur-xl">
          <div class="flex items-center gap-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-md bg-accent-500/10 dark:bg-accent-400/10 text-accent-600 dark:text-accent-400">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            </span>
            <h3 class="font-medium text-secondary-900 dark:text-secondary-100">Algorithmic Trading</h3>
          </div>
          <p class="mt-3 text-sm text-secondary-500 dark:text-secondary-400">
            Automated options wheel strategy, stock screening algorithms, and prediction market agents — building toward full trading automation.
          </p>
        </div>
      </div>
    </section>

    <!-- Divider -->
    <hr class="my-14 border-secondary-200 dark:border-white/[0.08]" />

    <!-- Skills & Tech Stack -->
    <section>
      <h2 class="text-xl font-semibold text-secondary-900 dark:text-secondary-100">
        Skills &amp; Tech Stack
      </h2>
      <p class="mt-2 text-secondary-500 dark:text-secondary-400 text-sm">
        Technologies and tools I reach for, organized by what they do.
      </p>

      <div class="mt-6 space-y-6">

        <!-- Languages -->
        <div>
          <h3 class="text-xs font-semibold tracking-widest uppercase text-secondary-400 dark:text-secondary-500 mb-3">
            Languages
          </h3>
          <div class="flex flex-wrap gap-2">
            {['Python', 'TypeScript', 'JavaScript', 'Bash', 'SQL', 'Go'].map((skill) => (
              <span class="inline-flex items-center rounded-md bg-secondary-100 dark:bg-white/[0.05] px-3 py-1 text-sm font-medium text-secondary-700 dark:text-secondary-200 ring-1 ring-inset ring-secondary-200 dark:ring-white/10">
                {skill}
              </span>
            ))}
          </div>
        </div>

        <!-- AI & Automation -->
        <div>
          <h3 class="text-xs font-semibold tracking-widest uppercase text-secondary-400 dark:text-secondary-500 mb-3">
            AI &amp; Automation
          </h3>
          <div class="flex flex-wrap gap-2">
            {['LangChain', 'LangGraph', 'Ollama', 'OpenRouter', 'MCP', 'AI Agents'].map((skill) => (
              <span class="inline-flex items-center rounded-md bg-secondary-100 dark:bg-white/[0.05] px-3 py-1 text-sm font-medium text-secondary-700 dark:text-secondary-200 ring-1 ring-inset ring-secondary-200 dark:ring-white/10">
                {skill}
              </span>
            ))}
          </div>
        </div>

        <!-- Infrastructure & Cloud -->
        <div>
          <h3 class="text-xs font-semibold tracking-widest uppercase text-secondary-400 dark:text-secondary-500 mb-3">
            Infrastructure &amp; Cloud
          </h3>
          <div class="flex flex-wrap gap-2">
            {['AWS', 'GCP', 'Cloudflare', 'Firebase', 'Hetzner', 'Docker', 'Terraform', 'GitHub Actions'].map((skill) => (
              <span class="inline-flex items-center rounded-md bg-secondary-100 dark:bg-white/[0.05] px-3 py-1 text-sm font-medium text-secondary-700 dark:text-secondary-200 ring-1 ring-inset ring-secondary-200 dark:ring-white/10">
                {skill}
              </span>
            ))}
          </div>
        </div>

        <!-- Security & Networking -->
        <div>
          <h3 class="text-xs font-semibold tracking-widest uppercase text-secondary-400 dark:text-secondary-500 mb-3">
            Security &amp; Networking
          </h3>
          <div class="flex flex-wrap gap-2">
            {['Zscaler', 'Zero Trust', 'Kali', 'CodeQL', 'Juniper Mist', 'tmux', 'Linux', 'Alpaca API'].map((skill) => (
              <span class="inline-flex items-center rounded-md bg-secondary-100 dark:bg-white/[0.05] px-3 py-1 text-sm font-medium text-secondary-700 dark:text-secondary-200 ring-1 ring-inset ring-secondary-200 dark:ring-white/10">
                {skill}
              </span>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- Divider -->
    <hr class="my-14 border-secondary-200 dark:border-white/[0.08]" />

    <!-- Get in Touch -->
    <section>
      <h2 class="text-xl font-semibold text-secondary-900 dark:text-secondary-100">
        Get in Touch
      </h2>
      <p class="mt-2 text-secondary-500 dark:text-secondary-400 text-sm">
        Always open to conversations about architecture, engineering, and interesting problems.
      </p>

      <div class="mt-6 flex flex-wrap gap-4">
        <!-- GitHub -->
        <a
          href="https://github.com/vahagn-madatyan"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="inline-flex items-center gap-2.5 rounded-lg border border-secondary-200 dark:border-white/[0.08] bg-secondary-50 dark:bg-white/[0.03] px-5 py-3 text-sm font-medium text-secondary-700 dark:text-secondary-300 hover:border-primary-300 dark:hover:border-primary-500/30 hover:text-primary-600 dark:hover:text-primary-400 dark:hover:shadow-[0_0_15px_rgba(16,185,129,0.1)] transition-all"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0016 8c0-4.42-3.58-8-8-8z" />
          </svg>
          GitHub
        </a>

        <!-- LinkedIn -->
        <a
          href="https://linkedin.com/in/mvahagn"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="inline-flex items-center gap-2.5 rounded-lg border border-secondary-200 dark:border-white/[0.08] bg-secondary-50 dark:bg-white/[0.03] px-5 py-3 text-sm font-medium text-secondary-700 dark:text-secondary-300 hover:border-primary-300 dark:hover:border-primary-500/30 hover:text-primary-600 dark:hover:text-primary-400 dark:hover:shadow-[0_0_15px_rgba(16,185,129,0.1)] transition-all"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
          LinkedIn
        </a>

        <!-- X (Twitter) -->
        <a
          href="https://x.com/vahagndev"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="X (Twitter)"
          class="inline-flex items-center gap-2.5 rounded-lg border border-secondary-200 dark:border-white/[0.08] bg-secondary-50 dark:bg-white/[0.03] px-5 py-3 text-sm font-medium text-secondary-700 dark:text-secondary-300 hover:border-primary-300 dark:hover:border-primary-500/30 hover:text-primary-600 dark:hover:text-primary-400 dark:hover:shadow-[0_0_15px_rgba(16,185,129,0.1)] transition-all"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
          X (Twitter)
        </a>

        <!-- Email -->
        <a
          href="mailto:me@vahagn.dev"
          aria-label="Email"
          class="inline-flex items-center gap-2.5 rounded-lg border border-secondary-200 dark:border-white/[0.08] bg-secondary-50 dark:bg-white/[0.03] px-5 py-3 text-sm font-medium text-secondary-700 dark:text-secondary-300 hover:border-primary-300 dark:hover:border-primary-500/30 hover:text-primary-600 dark:hover:text-primary-400 dark:hover:shadow-[0_0_15px_rgba(16,185,129,0.1)] transition-all"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Email
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
