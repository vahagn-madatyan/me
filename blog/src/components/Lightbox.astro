---
/* Lightbox — native <dialog> modal for full-size image viewing.
   Triggered by any element with a data-lightbox-src attribute. */
---

<dialog
  id="lightbox-dialog"
  class="fixed inset-0 z-50 m-0 h-screen w-screen max-h-none max-w-none border-none bg-transparent p-0"
>
  <div class="flex h-full w-full items-center justify-center p-4 sm:p-8" id="lightbox-backdrop">
    <!-- Close button -->
    <button
      id="lightbox-close"
      type="button"
      class="absolute right-4 top-4 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-black/50 text-white backdrop-blur-sm transition-colors hover:bg-black/70 focus:outline-none focus:ring-2 focus:ring-white/50"
      aria-label="Close lightbox"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Image -->
    <img
      id="lightbox-img"
      src=""
      alt=""
      class="max-h-[85vh] max-w-[90vw] rounded-lg object-contain shadow-2xl sm:max-h-[90vh] sm:max-w-[85vw]"
    />
  </div>
</dialog>

<style>
  dialog::backdrop {
    background: rgba(0, 0, 0, 0.8);
  }

  dialog[open] {
    display: flex;
  }
</style>

<script>
  function initLightbox() {
    const dialog = document.getElementById('lightbox-dialog') as HTMLDialogElement | null;
    const img = document.getElementById('lightbox-img') as HTMLImageElement | null;
    const closeBtn = document.getElementById('lightbox-close');
    const backdrop = document.getElementById('lightbox-backdrop');

    if (!dialog || !img || !closeBtn || !backdrop) return;

    // Open lightbox when any [data-lightbox-src] element is clicked
    const triggers = document.querySelectorAll<HTMLElement>('[data-lightbox-src]');
    triggers.forEach((trigger) => {
      trigger.onclick = () => {
        const src = trigger.dataset.lightboxSrc;
        if (src) {
          img.src = src;
          img.alt = trigger.dataset.lightboxAlt || 'Architecture diagram';
          dialog.showModal();
        }
      };
    });

    // Close via button
    closeBtn.onclick = () => dialog.close();

    // Close on backdrop click (click on backdrop div, not on the image)
    backdrop.onclick = (e: MouseEvent) => {
      if (e.target === backdrop) {
        dialog.close();
      }
    };

    // Escape is handled natively by <dialog>
  }

  initLightbox();
  document.addEventListener('astro:after-swap', initLightbox);
</script>
