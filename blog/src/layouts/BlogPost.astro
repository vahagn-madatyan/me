---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../components/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import ShareButtons from '../components/ShareButtons.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import CopyButton from '../components/CopyButton.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { formatReadingTime } from '../utils/reading-time';

type Props = CollectionEntry<'blog'>['data'] & {
  readingTime: number;
  slug?: string;
  allPosts?: CollectionEntry<'blog'>[];
  currentSlug?: string;
  currentTags?: string[];
  headings?: Array<{ depth: number; slug: string; text: string }>;
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tags = [],
  readingTime,
  canonicalURL,
  slug,
  allPosts = [],
  currentSlug,
  currentTags = [],
  headings = [],
} = Astro.props;

// Derive slug from page URL if not passed explicitly
const derivedSlug = slug || Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');

// Construct full post URL for share buttons
const fullUrl = new URL('/blog/' + derivedSlug + '/', Astro.site || 'https://vahagn.dev').toString();

// Show TOC only for long posts with headings
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
const showToc = tocHeadings.length > 0 && readingTime >= 5;
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  pubDate={pubDate}
  updatedDate={updatedDate}
  tags={tags}
  slug={derivedSlug}
  {...(canonicalURL ? { canonicalOverride: canonicalURL } : {})}
>
  {showToc ? (
    <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:grid lg:grid-cols-[1fr_250px] lg:gap-8">
      <article>
        {heroImage && (
          <div class="mb-8">
            <Image
              width={1020}
              height={510}
              src={heroImage}
              alt=""
              class="w-full rounded-xl dark:ring-1 dark:ring-white/10"
            />
          </div>
        )}
        <div class="mb-8 text-center">
          <div class="flex items-center justify-center gap-1.5 text-sm font-code text-secondary-500 dark:text-secondary-400 mb-3">
            <FormattedDate date={pubDate} />
            <span aria-hidden="true">&middot;</span>
            <span>{formatReadingTime(readingTime)}</span>
          </div>
          {updatedDate && (
            <p class="text-sm text-secondary-500 dark:text-secondary-400 italic mb-3">
              Last updated on <FormattedDate date={updatedDate} />
            </p>
          )}
          <h1 class="text-3xl font-bold tracking-tight text-secondary-900 dark:text-secondary-100 sm:text-4xl">
            {title}
          </h1>
          {description && (
            <p class="mt-3 text-lg text-secondary-600 dark:text-secondary-400">
              {description}
            </p>
          )}
          {tags.length > 0 && (
            <div class="mt-4 flex flex-wrap justify-center gap-2">
              {tags.map((tag) => (
                <a href={"/blog/tag/" + tag + "/"} class="rounded-full bg-primary-100 px-2.5 py-0.5 text-xs font-medium font-code text-primary-800 transition-colors hover:bg-primary-200 dark:bg-primary-500/10 dark:text-primary-300 dark:ring-1 dark:ring-primary-500/20 dark:hover:bg-primary-500/20">
                  {tag}
                </a>
              ))}
            </div>
          )}
          <hr class="mt-6 border-secondary-200 dark:border-white/[0.08]" />
          <ShareButtons url={fullUrl} title={title} />
        </div>
        <div class="prose prose-secondary dark:prose-invert max-w-none text-secondary-700 dark:text-secondary-300 leading-relaxed">
          <slot />
        </div>
        <RelatedPosts
          currentSlug={currentSlug || derivedSlug}
          currentTags={currentTags}
          allPosts={allPosts}
        />
      </article>
      <div class="hidden lg:block">
        <TableOfContents headings={headings} />
      </div>
    </div>
  ) : (
    <article class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
      {heroImage && (
        <div class="mb-8">
          <Image
            width={1020}
            height={510}
            src={heroImage}
            alt=""
            class="w-full rounded-xl dark:ring-1 dark:ring-white/10"
          />
        </div>
      )}
      <div class="mb-8 text-center">
        <div class="flex items-center justify-center gap-1.5 text-sm font-code text-secondary-500 dark:text-secondary-400 mb-3">
          <FormattedDate date={pubDate} />
          <span aria-hidden="true">&middot;</span>
          <span>{formatReadingTime(readingTime)}</span>
        </div>
        {updatedDate && (
          <p class="text-sm text-secondary-500 dark:text-secondary-400 italic mb-3">
            Last updated on <FormattedDate date={updatedDate} />
          </p>
        )}
        <h1 class="text-3xl font-bold tracking-tight text-secondary-900 dark:text-secondary-100 sm:text-4xl">
          {title}
        </h1>
        {description && (
          <p class="mt-3 text-lg text-secondary-600 dark:text-secondary-400">
            {description}
          </p>
        )}
        {tags.length > 0 && (
          <div class="mt-4 flex flex-wrap justify-center gap-2">
            {tags.map((tag) => (
              <a href={"/blog/tag/" + tag + "/"} class="rounded-full bg-primary-100 px-2.5 py-0.5 text-xs font-medium text-primary-800 transition-colors hover:bg-primary-200 dark:bg-primary-900 dark:text-primary-200 dark:hover:bg-primary-800">
                {tag}
              </a>
            ))}
          </div>
        )}
        <hr class="mt-6 border-secondary-200 dark:border-secondary-800" />
        <ShareButtons url={fullUrl} title={title} />
      </div>
      <div class="prose prose-secondary dark:prose-invert max-w-none text-secondary-700 dark:text-secondary-300 leading-relaxed">
        <slot />
      </div>
      <RelatedPosts
        currentSlug={currentSlug || derivedSlug}
        currentTags={currentTags}
        allPosts={allPosts}
      />
    </article>
  )}
  <CopyButton />
</BaseLayout>

<style>
  .dark .prose :global(a) {
    text-decoration-color: rgba(16, 185, 129, 0.3);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s, color 0.2s;
  }
  .dark .prose :global(a:hover) {
    text-decoration-color: rgba(16, 185, 129, 0.8);
    text-shadow: 0 0 12px rgba(16, 185, 129, 0.2);
  }
</style>
