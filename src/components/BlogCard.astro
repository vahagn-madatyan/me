---
import { Image } from 'astro:assets';
import FormattedDate from './FormattedDate.astro';
import { formatReadingTime } from '../utils/reading-time';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  heroImage?: ImageMetadata;
  tags?: string[];
  readingTime: number;
  slug: string;
}

const { title, description, pubDate, heroImage, tags = [], readingTime, slug } = Astro.props;
---

<article class="group rounded-2xl bg-white shadow-sm ring-1 ring-secondary-200 transition-all duration-300 hover:shadow-lg hover:ring-primary-300 dark:bg-white/[0.03] dark:ring-white/[0.08] dark:backdrop-blur-xl dark:hover:ring-primary-500/30 dark:hover:shadow-[0_0_30px_rgba(16,185,129,0.07),0_8px_32px_rgba(0,0,0,0.3)] overflow-hidden">
  {heroImage && (
    <a href={`/blog/${slug}/`} class="block overflow-hidden" aria-hidden="true" tabindex="-1">
      <Image
        width={720}
        height={360}
        src={heroImage}
        alt=""
        class="aspect-video w-full object-cover transition-transform duration-300 group-hover:scale-105"
      />
    </a>
  )}
  <div class="p-5 sm:p-6">
    <h2 class="text-lg font-semibold leading-snug tracking-tight text-secondary-900 dark:text-secondary-100">
      <a
        href={`/blog/${slug}/`}
        class="transition-colors duration-200 hover:text-primary-600 dark:hover:text-primary-400"
      >
        {title}
      </a>
    </h2>
    <p class="mt-2 text-sm leading-relaxed text-secondary-600 dark:text-secondary-400">
      {description}
    </p>
    <div class="mt-4 flex flex-wrap items-center justify-between gap-2 text-xs font-code text-secondary-500 dark:text-secondary-400">
      <div class="flex items-center gap-1.5">
        <FormattedDate date={pubDate} />
        <span aria-hidden="true">&middot;</span>
        <span>{formatReadingTime(readingTime)}</span>
      </div>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {tags.map((tag) => (
            <a href={"/blog/tag/" + tag + "/"} class="rounded-full bg-primary-100 px-2 py-0.5 text-xs font-medium text-primary-800 transition-colors hover:bg-primary-200 dark:bg-primary-500/10 dark:text-primary-300 dark:ring-1 dark:ring-primary-500/20 dark:hover:bg-primary-500/20">
              {tag}
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</article>
